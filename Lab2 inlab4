.data
Input_Msg: .asciiz "Enter an alphabetic character: "
Output_Msg: .asciiz "\nThe opposite case of given character in the is: "
Error_Msg: .asciiz "\nError: Input character is not alphabetic."
newline: .asciiz "/n"

.text
    la $a0, Input_Msg  # Read input character
    li $v0, 4
    syscall

    li $v0, 12        # Read input character
    syscall
    move $t0, $v0

    blt $t0, 'A', not_uppercase    # Check if character is uppercase
    ble $t0, 'Z', uppercase
    
not_uppercase:
    blt $t0, 'a', not_lowercase   # Check if character is lowercase
    ble $t0, 'z', lowercase
    
not_lowercase:  
    la $a0, Error_Msg     # If character not alphabetic, print Error message
    li $v0, 4
    syscall
    j exit

uppercase:
    addi $t0, $t0, 32     # Convert uppercase to lowercase
    j print_output

lowercase:
    subi $t0, $t0, 32     # Print output message
    j print_output

print_output:
    la $a0, Output_Msg    # Print output message
    li $v0, 4
    syscall

    move $a0, $t0   # Print output character
    li $v0, 11
    syscall

exit:
    li $v0, 10      # Exit program
    syscall


