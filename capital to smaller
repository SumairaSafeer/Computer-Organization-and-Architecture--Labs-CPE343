.data
    prompt:      .asciiz "Enter an Alphabetic character: "
    result:      .asciiz "\nThe character in the Opposite Case is: "
    newline:     .asciiz "\n"
.text
main:
    li $v0, 4               # syscall to print string
    la $a0, prompt          # address of the prompt string
    syscall

    li $v0, 12              # syscall to read a character
    syscall
    move $t0, $v0           # store the input character in $t0

    # Check if the character is lowercase (a-z)
    li $t1, 97                      # ASCII value of 'a'
    li $t2, 122                     # ASCII value of 'z'
    blt $t0, $t1, check_uppercase   # If less than 'a', check uppercase
    bgt $t0, $t2, check_uppercase   # If greater than 'z', check uppercase

    # Convert lowercase to uppercase
    li $t3, 32               # Difference between uppercase and lowercase
    sub $t0, $t0, $t3        # Convert to uppercase
    j display_result         # Jump to display result

check_uppercase:
    li $t1, 65                    # ASCII value of 'A'
    li $t2, 90                    # ASCII value of 'Z'
    blt $t0, $t1, invalid_input   # If less than 'A', invalid input
    bgt $t0, $t2, invalid_input   # If greater than 'Z', invalid input

    # Convert uppercase to lowercase
    li $t3, 32              # Difference between uppercase and lowercase
    add $t0, $t0, $t3       # Convert to lowercase

display_result:
    # Print the result
    li $v0, 4               # syscall to print string
    la $a0, result          # address of the result string
    syscall

    # Print the converted character
    li $v0, 11              # syscall to print a character
    move $a0, $t0           # character to print
    syscall

    li $v0, 4               
    la $a0, newline         # address of the newline string
    syscall

    li $v0, 10              # syscall to exit
    syscall

invalid_input:
    li $v0, 4               # syscall to print string
    la $a0, newline         # print newline
    syscall

    la $a0, "Invalid input. Please enter an alphabetic character.\n"
    syscall

    li $v0, 10   # Exit the program
    syscall
